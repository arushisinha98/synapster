# Vercel (frontend) — set these in Vercel project settings
NEXT_PUBLIC_API_URL=https://xxxx-xxxx.trycloudflare.com
NEXT_PUBLIC_PASSWORD=changeme

# Backend (MBP-2 / wherever FastAPI runs) — keep secret
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: tighten CORS to the exact Vercel domain
ALLOWED_ORIGIN=https://your-app.vercel.app
